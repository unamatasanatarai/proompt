#!/usr/bin/env bash

__data_dir="${XDG_DATA_HOME:-$HOME/.local/share}/proompt"

__prompt_id="$1"
__source_path="$__data_dir/$__prompt_id"

if [[ -z "$__prompt_id" ]]; then
    printf 'Usage: %s <prompt-id>\n' "${0##*/}" >&2
    exit 1
fi

if [[ ! -f "$__source_path" ]]; then
    printf "Error: Prompt '%s' not found in local cache.\n" "$__prompt_id" >&2
    exit 2
fi

while IFS= read -r __line || [[ -n "$__line" ]]; do
    printf '%s\n' "$__line"
done <"$__source_path"
