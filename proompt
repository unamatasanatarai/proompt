#!/usr/bin/env bash

__dir="${0%/*}"
[[ "$0" == "$__dir" ]] && __dir="."
export PATH="$__dir:$PATH"

__cmd="$1"

case "$__cmd" in
"" | list)
    shift || true
    proompt-list "$@"
    ;;
get)
    shift || true
    proompt-get "$@"
    ;;
copy)
    shift || true
    proompt-copy "$@"
    ;;
update)
    shift || true
    proompt-update "$@"
    ;;
-h | --help | help)
    printf 'usage: %s [command | proompt-id]\n\n' "${0##*/}"
    printf 'commands:\n'
    printf '  list   - list available proompts (local cache)\n'
    printf '  get    - apply a proompt to a file\n'
    printf '  copy   - copy a proompt to the clipboard\n'
    printf '  update - download/sync all available proompts\n\n'
    printf 'shorthand:\n'
    printf '  %s <proompt-id>  (alias for copy)\n\n' "${0##*/}"
    printf 'example usage:\n'
    printf '  %s update\n' "${0##*/}"
    printf '  %s list\n' "${0##*/}"
    printf '  %s copy meta\n' "${0##*/}"
    exit 0
    ;;
*)
    proompt-copy "$@"
    ;;
esac
